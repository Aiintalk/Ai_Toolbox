# JWT 签名密钥（生产环境必须改成 32 字节以上随机字符串）
# 可用 `openssl rand -base64 32` 生成
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes

# JWT 有效期（小时）
JWT_TTL_HOURS=168

# 初始化 admin 账号（只在 init-db 时使用）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Cookie 域，本地开发留空，生产环境填服务器主域（如 .example.com）
COOKIE_DOMAIN=
